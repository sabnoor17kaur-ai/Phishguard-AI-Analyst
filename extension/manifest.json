{
  "manifest_version": 3,
  "name": "PhishGuard",
  "version": "1.0",
  "description": "AI Powered Phishing Detection",

  "permissions": [
  "tabs",
  "storage"
],
  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}